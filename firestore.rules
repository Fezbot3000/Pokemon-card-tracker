rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User profiles
    match /users/{userId} {
      // Users can read and update their own profile
      allow read, update: if isOwner(userId);
      // Only the auth system can create profiles (during registration)
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Collections
    match /users/{userId}/collections/{collectionId} {
      // Users can only access their own collections
      allow read, write: if isOwner(userId);
    }
    
    // Image metadata
    match /users/{userId}/imageMetadata/{imageId} {
      // Users can only access their own image metadata
      allow read, write: if isOwner(userId);
    }
    
    // Backups metadata
    match /users/{userId}/backups/{backupId} {
      // Users can only access their own backup metadata
      allow read, write: if isOwner(userId);
    }
    
    // Denying access to all other documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 